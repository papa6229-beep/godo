{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "strict": false,
    "strictNullChecks": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noEmit": true,
    "noEmitOnError": true
  },
  "include": ["**/*.ts", "**/*.tsx", "**/*.mts", "**/*.cts"]
}
