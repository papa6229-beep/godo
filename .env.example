# Godomall5 Open API Secure Proxy 연동 설정 템플릿
# 주의: 이 파일은 설정 예시이며, 실제 비밀키는 로컬 .env 또는 Vercel 환경변수에만 등록하고 git에 올리지 마십시오.
# 키 원문은 프론트엔드/localStorage/응답 JSON 어디에도 노출되지 않습니다.

# 연동 모드: real | sandbox | mock
GODOMALL_API_MODE=mock

# 고도몰5 Open API 인증 키 (OpenHub)
GODOMALL_PARTNER_KEY=
GODOMALL_USER_KEY=

# OpenHub Base URL (도메인 직접 호출이 아닌 OpenHub 도메인 사용)
GODOMALL_REAL_BASE_URL=https://openhub.godo.co.kr/godomall5
GODOMALL_SANDBOX_BASE_URL=http://sbopenhub.godo.co.kr/godomall5

# ── 마케팅 행동 이벤트 저장소 (선택) ─────────────────────────────────────────
# 미설정 시 dev_buffer(비영속) 유지. 아래를 모두 채우면 Postgres persistent로 승격.
# 실제 값은 Vercel 환경변수에만 등록하고 git에 올리지 마십시오(secret 노출 금지).
# GODO_BEHAVIOR_STORAGE_BACKEND=postgres
# DATABASE_URL=
# POSTGRES_URL=
# GODO_BEHAVIOR_POSTGRES_TABLE=marketing_behavior_events
# GODO_BEHAVIOR_POSTGRES_SSL=true
# GODO_BEHAVIOR_POSTGRES_MAX_EVENTS=10000
# 행동 수집 origin allowlist(쉼표 구분, 와일드카드 금지)
# GODO_BEHAVIOR_ALLOWED_ORIGINS=
